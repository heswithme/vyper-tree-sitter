{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "vyper",
      "camelcase": "Vyper",
      "title": "Vyper",
      "scope": "source.vyper",
      "file-types": [
        ".vy",
        ".vyi"
      ],
      "injection-regex": "^vyper$",
      "class-name": "TreeSitterVyper"
    }
  ],
  "metadata": {
    "version": "0.0.1",
    "license": "MIT",
    "description": "Tree-sitter grammar for Vyper",
    "authors": [
      {
        "name": "heswithme"
      }
    ],
    "links": {
      "repository": "https://github.com/heswithme/tree-sitter-vyper"
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
